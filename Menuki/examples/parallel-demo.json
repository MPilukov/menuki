              { "type": "shell", "command": "sleep 1; echo one" },
              { "type": "shell", "command": "sleep 1; echo two" },
              { "type": "shell", "command": "sleep 1; echo three" },
              { "type": "shell", "command": "sleep 1; echo four" }
            ] } },
        { "name": "Exit", "action": { "type": "exit" } }
